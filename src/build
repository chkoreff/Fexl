#!/bin/sh
. ./lib_build

# Build fexl.
make basic
make buffer
make context
make die
make format
make limit
make memory
make output
make parse
make run
make show
make str
make stream
make type_form
make type_limit
make type_math
make type_meta
make type_num
make type_output
make type_record
make type_str
make type_var
make value

make fexl
link fexl
