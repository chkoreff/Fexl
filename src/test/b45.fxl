#
use "lib/object/render.fxl"
evaluate \;

# Test converting string to object and back again.
\test_convert=
	(\str
	\obj_2=(str_obj str)
	\str_2=(obj_str obj_2)
	eq str str_2 ();
	say "BAD:"
	put str_2
	)

show_benchmark;

\obj=
	(
	\q="q"

	\obj=empty
	set obj "x" (+ 0 1)
	set obj "y" 2
	set obj 3 "whatever"
	set obj q (. q q)
	set obj "obj"
		(
		\obj=empty
		set obj "a" 11
		set obj "b" 22
		set obj "c" I
		obj
		)
	set obj "list"
		[
		2
		"abc"
		void
		(
		\obj=empty
		set obj "a" 47
		set obj "b" 82
		obj
		)
		]
	set obj "flag" (I I T)
	set obj "tuple"
		{"a" 2 [{"c" 3} {"d" 4}]
		(
		\obj=empty
		set obj "x" 3
		set obj "flag" F
		obj
		)
		}
	set obj "e"
		(
		\obj=empty
		obj
		)
	obj
	)

\\test_1=
	(
	say "= test_1"
	\try=
		(\x
		\y=(obj x)
		say [x" => "y]
		)

	\\run=
		(
		try "x"
		try 3
		try "y"
		try "q"
		try "z"
		nl
		)

	run
	run
	run
	)

\\test_2=
	(
	say "= test_2"
	\try=
		(\obj
		\str=(obj_str obj)
		say "===="
		put str
		test_convert str
		)

	try obj
	try (obj "y")
	try (obj 3)
	try (obj "obj")
	try (obj "list")
	try (obj "z")
	try (obj "obj" "b")
	try (obj "obj" "z")
	try (I void)
	)

test_1
test_2
