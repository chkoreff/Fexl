#
show_benchmark;

(
# Test storing random key-val pairs in a record.
\obj=empty

\add_random_keys=
	(@\\loop\count\seed
	le count 0 ();
	\hash=(sha512 seed)
	\key=(unpack; slice hash 0 8)
	\val=(unpack; slice hash 32 8)
	set obj key val
	loop (- count 1) hash
	)

add_random_keys 8192 "abcd"

(
\key="7d13f23fa2b9a6fd"
\val=(obj key)
say_data {key val}
set obj key "ffff"
\val=(obj key)
say_data {key val}
set obj key (. "aaaa"; obj key)
\val=(obj key)
say_data {key val}
)

(
\pair=(record_item obj 0)
put "first = "
say_data pair
)

(
\pair=(record_item obj (+ -1; record_count obj))
put "last  = "
say_data pair
)
)

(
# Test group items by lower-case.
say "= group_items"
\xs=["A" "b" "c" "b" "a" "a" "a" "B" "c" "d" "C" "b" "a" "a"]
say ["xs = "(as_str xs)]
\ys=(group_items lc xs)
say ["ys = "(as_str ys)]
)

(
# Test merge_keys.
say "= merge_keys"
\xs=[{"a" 1} {"b" 2} {"d" 4} {"g" 7}]
\ys=[{"a" -1} {"c" -3} {"d" -4} {"e" -5} {"f" -6}]
merge_keys (\x\y {x y}) xs ys \L\M\R
say ["xs = "(as_str xs)]
say ["ys = "(as_str ys)]
say ["L  = "(as_str L)]
say ["M  = "(as_str M)]
say ["R  = "(as_str R)]
)

(
say "= map_bytes_to_double"
\try=
	(\bytes
	\x=(map_bytes_to_double bytes)
	say [(as_str bytes)" => "x]
	)
try [0 0 0 0 0 0 0] # 0
try [255 255 255 255 255 255 63] # 0.25
try [255 255 255 255 255 255 127] # 0.5
try [27 220 180 171 62 7 156] # 0.609485546989945
try [255 255 255 255 255 255 191] # 0.75
try [193 214 112 19 131 147 234] # 0.916313354727062
try [255 255 255 255 255 255 255] # 1
)
