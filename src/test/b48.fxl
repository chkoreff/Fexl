# Test unwind
\\unwind=
	(
	T unwind;  # Use the built in version written in C.
	@\loop\xs\f
	xs f \x\xs
	loop xs (f x)
	)

\\print=
	(@\loop\xs
	xs nl \_\xs
	\x
	put " " put x
	loop xs
	)

\try=
	(\xs
	put ":"
	unwind xs (print xs)
	)

(
say "= test_2349"
show_benchmark;
try []
try ["a"]
try ["a" "b"]
try ["a" "b" "c"]
try ["a" "b" "c" "d"]

# Call print directly.  The list encodes the number of items to print.
put ":" print []
put ":" print [I] "a"
put ":" print [I I] "a" "b"
put ":" print [I I I] "a" "b" "c"
put ":" print [I I I I] "a" "b" "c" "d"
)

(
say "= test_8877"
\try=(\\exp put ": " show exp nl)

show_benchmark;
try (unwind (() []) 37)

try
	(
	unwind
		(
		I;
		cons "a";
		cons "b";
		I;
		null
		)
		(\x\y
		put "x = " say x
		put "y = " say y
		37
		)
	)

try (unwind "a" 37)
)

# Test raw forms.
(
say "= test_0114"
\try=(\f put ": " show f nl)

try {}
try {1}
try {1 2}
try {1 2 3}
try {1 2 3 4}
try {1 2{3 4}}
try
	(
	\a="a"
	\b=(() () "b")
	\d="d"
	{a b "c" (. "" d) "e"}
	)
nl
)

# Test using tuples as functions.
(
say "= test_6521"

\\print=
	(@\loop\xs
	xs nl \_\xs
	\x
	put " " put x
	loop xs
	)

\try=
	(\xs\tuple
	tuple;
	put ":" print xs
	)

try [] {}
try [I] {"a"}
try [I I] {"a" "b"}
try [I I I I I]
	(
	\a="a"
	\b=(() () "b")
	\d="d"
	{a b "c" (. "" d) "e"}
	)
)

say "END"
