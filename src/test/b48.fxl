# Test tuples

(
say "= test_8501"
{"a" "b" "c"} \a\b\c
put "a = " say a
put "b = " say b
put "c = " say c
say "."
)

(
say "= test_2777"
\tuple=
	(
	I; I;
	\b="b"
	\e="e"
	{"a" b "c"; cons "d"; cons e; cons "f"; null}
	)

tuple;
put ":"
\x put " " put x
\x put " " put x
\x put " " put x
\x put " " put x
\x put " " put x
\x put " " put x
nl
)

(
say "= test_6103"
put ":"
{"a" "b"; 3} # improper list
\x put " " put x
\x put " " put x
\tail put "; " show tail
nl
)

(
# Test tuple_to_list
say "= test_6469"
\try=
	(\x
	\\x=(tuple_to_list x)
	put ": " show x nl
	)

try 3
try {}
try (I {"a" "b"})
try {"a" "b"; "c"} # improper list
try (list_to_tuple (cons "a"; cons "b"; null))
)

(
say "= test_1723"
list_to_tuple ["a" "b" "c"] \a\b\c
put "a = " say a
put "b = " say b
put "c = " say c
say "."
)

(
say "= test_3290"
\try=(\\f put ": " show f nl)

try (list_to_tuple [])
try (list_to_tuple ["a"])
try (list_to_tuple ["a" "b"])
try (list_to_tuple ["a" "b"; () () ["c" "d"]])

try (list_to_tuple 3)
try (list_to_tuple ["a" "b";3]) # improper list
)

# Print a list of strings.
\\print=
	(@\loop\xs
	xs nl \x\xs
	put " " put x
	loop xs
	)

(
say "= test_2349"

\try=(\xs put ":" print xs)

show_benchmark;
try []
try ["a"]
try ["a" "b"]
try ["a" "b" "c"]
try ["a" "b" "c" "d"]
)

(
say "= test_8877"
\try=(\\f put ": " show f nl)

show_benchmark;

try (list_to_tuple (() []) 37)

try
	(
	list_to_tuple
		(
		I;
		cons "a";
		cons "b";
		I;
		null
		)
		(\x\y
		put "x = " say x
		put "y = " say y
		37
		)
	)

try (list_to_tuple "a" 37)
)

# Test raw forms.
(
say "= test_0114"
\try=(\f put ": " show f nl)

try {}
try {1}
try {1 2}
try {1 2 3}
try {1 2 3 4}
try {1 2{3 4}}
try
	(
	\a="a"
	\b=(() () "b")
	\d="d"
	{a b "c" (. "" d) "e"}
	)
nl
)

(
say "= test_6521"

\try=(\tuple put ":" print (tuple_to_list tuple))

show_benchmark;

try {}
try {"a"}
try {"a" "b"}
try
	(
	\a="a"
	\b=(() () "b")
	\d="d"
	{a b "c" (. "" d) "e"}
	)
)

say "END"
