# Test unwind
\\unwind=
	(
	T unwind;  # Use the built in version written in C.
	@\loop\xs\f
	xs f \x\xs
	loop xs (f x)
	)

\\print=
	(@\loop\xs
	xs nl \_\xs
	\x
	put " " put x
	loop xs
	)

\try=
	(
	\xs
	put ":"
	unwind xs (print xs)
	)

(
show_benchmark;
try []
try ["a"]
try ["a" "b"]
try ["a" "b" "c"]
try ["a" "b" "c" "d"]

# Call print directly.  The list encodes the number of items to print.
put ":" print []
put ":" print [I] "a"
put ":" print [I I] "a" "b"
put ":" print [I I I] "a" "b" "c"
put ":" print [I I I I] "a" "b" "c" "d"
)

(
\try=(\\exp put ": " show exp nl)

show_benchmark;
try (unwind (() []) 37)

try
	(
	unwind
		(
		I;
		cons "a";
		cons "b";
		I;
		null
		)
		(\x\y
		put "x = " say x
		put "y = " say y
		37
		)
	)

try (unwind "a" 37)
)
say "END"
