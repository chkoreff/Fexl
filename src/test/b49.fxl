#
\QU=~ "~

\try=
	(\cx\sym
	put "get " put QU put sym put QU
	put " = "
	get sym cx
		(say "no")
		(\val put "(" put "yes " show val put ")" nl)
	)

try std (I "fred")
try std "32.8" # numbers are not defined by the context

try std (I "+")
try std (. "" "I")
try std (. "co" "ns")
try std "get"

try std "I"
try std "fred"
try empty "I"
try std "fred"

(
\cx=
	(
	def "fred" 32;
	def "wilma" 64;
	empty
	)

try cx "I"
try cx "fred"
try cx "wilma"
)

try std "I"
try std "fred"
