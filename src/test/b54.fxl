# Test records
\try=(\\exp put ": " show exp nl)

try empty
try (def (I "x"))
try (def (I 3))
try (def (I "x") (say "HI"))
try (def (I "x") (say "HI"); I 3)
try (def (I "x") (say "HI"); I empty)
try
	(
	def "x" 1;
	def "y" 2;
	empty
	)
try
	(
	def "y" 2;
	def "x" 1;
	empty
	)

try
	(
	def "x" 1;
	def "x" 2;
	empty
	)

try
	(
	def "a" "0970";
	def "d" "7631";
	def "c" "0653";
	def "b" "1500";
	def "f" "2534";
	def "d" "6258";
	def "a" "1549";
	def "e" "1551";
	empty
	)

try
	(
	def "say" say;
	def "+" +;
	def "nl" nl;
	def "put" put;
	def "num_str" num_str;
	empty
	)

# Test chain operator.
try ::
try (:: (I empty))
try (:: (I 3))
try (:: (I empty) (I 3))
try (:: (I empty) (I; def "a" "3549"; empty))

try
	(
	::
		(
		def "a" "3549";
		empty
		)
		empty
	)

try
	(
	::
		(
		def "a" "3549";
		empty
		)
		(
		def "b" "3160";
		empty
		)
	)

try
	(
	::
		(
		def "a" "3549";
		empty
		)
		(
		def "a" "3160";
		empty
		)
	)

try
	(
	::
		(
		def "b" "3160";
		empty
		)
		(
		def "a" "3549";
		empty
		)
	)

try
	(
	::
		(
		def "x" "0205";
		def "e" "7709";
		def "c" "2609";
		def "aa" "0853";
		def "x" "2380";
		empty
		)
		(
		def "a" "0970";
		def "d" "7631";
		def "c" "0653";
		def "b" "1500";
		def "f" "2534";
		def "d" "6258";
		def "a" "1549";
		def "e" "1551";
		empty
		)
	)

# Test get
(
\\obj=
	(
	def "a" 1;
	def "b" 2;
	empty
	)

try get
try (get (I "a"))
try (get 3)
try (get (I "a") 3)
try (get (I "a") (I obj))
try (get "a" obj "NO" \val ["YES" val])
try (get "b" obj "NO" \val ["YES" val])
try (get "c" obj "NO" \val ["YES" val])
try (get "a" empty "NO" \val ["YES" val])
try (get "c" (def "c" 3; obj) "NO" \val ["YES" val])
)

# Test using record as function
(
\obj=
	(
	def "a" 1;
	def "b" 2;
	empty
	)
nl
try (obj (I "a"))
try (obj "b")
try (obj "c")
try (obj 3)
try (empty "a")
nl
)

# Test the set function which evaluates the val.
(
try set
try (set 3)
try (set "a")
try (set "a" (say "CALC" + 1 2))

\\obj=(set "a" (say "CALC" + 1 2); set "b" (* 4 7); empty)
try obj
try (obj "b")
try (obj (I "a"))
try (obj 3)
)
