# Test some record operations.
\update=
	(\obj\key\\fn
	set obj key (fn; obj key)
	)

\add=
	(\obj\key\val
	set obj key (get obj key val (+ val))
	)

\set_default=
	(\obj\key\val
	get obj key
		(set obj key val)
		(\_)
	)

\make_record=
	(\keys\vals
	\rec=empty
	(@\\loop\keys\vals
	keys () \key\keys
	vals () \val\vals
	\key=(trim_spaces key)
	set rec key val
	loop keys vals
	)
	keys vals
	rec
	)

\show=
	(\obj
	say "["
	walk_record obj
		(\key\val
		say_data {key val}
		)
	say "]"
	)

show_benchmark;

\x=empty

set x "a" 0
set x "b" 0
set x "c" 0

set x "a" 1
set x "b" 2
set x "c" 3

set x "d" 4
set x "e" 5
show x

del x "x"
del x "d"
del x "c"
show x

update x "a" (* 10)
update x "b" (+ 5)

add x "c" 1
add x "c" 20
show x

# Test updating record as I walk through it.
walk_record x
	(\key\val
	eq key "b" (set x key (+ 8 val));
	)
show x

set_default x "c" 0
set_default x "d" 4
show x

\y=(make_record ["a" "b" "c"] [1 2 3])
show y

show x
