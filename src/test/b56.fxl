\value= # TODO in C
	(\cx
	restrict (set "std" cx; cx)
	)

\std=
	(
	set "value" value;
	std
	)

\flintstones=
	(
	set "fred" (say "I am Fred.");
	set "wilma" (say "I am Wilma.");
	empty
	)

value
(
:: flintstones;
set "hello" (say "Hello");
std
)
\;

value std \;
value std \;

\try=(\cx\exp put ": " show cx exp nl)
hello
try std hello
try std fred
try (set "say" say; empty) fred # TODO need del to delete "fred" from std
fred
wilma
say "END"
