	)

\flintstones=
	(
	set "fred" (say "I am Fred.");
	set "wilma" (say "I am Wilma.");
	empty
	)

value
(
:: flintstones;
set "hello" (say "Hello");
std
)
\;

value std \;
value std \;

\try=(\exp put ": " show exp nl)
hello
try hello
try fred
fred
wilma
