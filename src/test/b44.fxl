# Test read file
(
\show=(show std)
\try=
	(\name
	put "read " show name nl
	\\exp=(restrict std; read name)
	put "exp = " show exp nl
	nl
	)

try "test/b44_1.fxl"
#try "" # stdin
try 3 # not a file name
)
(
\try=(\\exp put ": " show std exp nl)
try read
try (read 3)
try (read (I "test/b45_1.fxl"))
)
